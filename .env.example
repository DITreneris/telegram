# Nukopijuok į .env ir užpildyk. .env necommitink.
#
# Paleidimas:
#   1. python -m venv .venv
#   2. .venv\Scripts\activate  (Windows)
#   3. pip install -r requirements.txt
#   4. Užpildyk BOT_TOKEN ir ADMIN_CHAT_ID
#   5. python run.py
#
# ADMIN_CHAT_ID: skaitinis Telegram NAUDOTOJO id (effective_user), ne grupės pokalbio id.
#    Pvz. @userinfobot. Turi sutapti su id, kurį grąžina Telegram adminui.
# Siuntimas (/next): žinutės eina į pokalbį, kuriame paleista komanda (effective_chat),
#    ne pagal ADMIN_CHAT_ID (tai tik „kas gali valdyti“ tikrinimas).

BOT_TOKEN=
ADMIN_CHAT_ID=

# Neprivaloma: žurnalo detalumas (DEBUG, INFO, WARNING, ERROR, CRITICAL). Numatytai INFO.
LOG_LEVEL=INFO

# Planuotas siuntimas (JobQueue): 08:00, 08:30, 19:00, 19:30 pagal SCHEDULE_TZ. Numatytai išjungta.
# ENABLE_SCHEDULED_POSTING=true
# SCHEDULE_TZ=Europe/Vilnius
# Neprivaloma: kur siųsti automatiką. Jei nenurodytas — naudojamas ADMIN_CHAT_ID (tipinis DM su botu).
# Grupėje /next eina į effective_chat; tada čia nurodyk grupės pokalbio id.
# SCHEDULE_TARGET_CHAT_ID=
# Neprivaloma: jei suplanuotas siuntimas nepavyksta — trumpas pranešimas angliškai į admin DM (numatytai įjungta).
# SCHEDULE_NOTIFY_ON_FAILURE=false

# HTTP publish (Vercel / web) — žr. web/README.md
# PUBLISH_CHAT_ID=
